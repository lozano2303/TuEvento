# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 256 bits (32+ characters) for HMAC-SHA256
JWT_SECRET=your_jwt_secret_at_least_256_bits_long

# ─── OAuth — Google ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── OAuth — Facebook ────────────────────────────────────────────────────────
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret

# ─── Admin seed account ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourAdminPassword123@
ADMIN_ALIAS=AdminAlias

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Spring ───────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── Moderation ───────────────────────────────────────────────────────────────
NSFW_SERVICE_URL=http://nsfw-classifier:8000
NSFW_THRESHOLD=0.6
SIGHTENGINE_API_USER=your_api_user
SIGHTENGINE_API_SECRET=your_api_secret
SIGHTENGINE_MODELS=gore
SIGHTENGINE_THRESHOLD=0.6
